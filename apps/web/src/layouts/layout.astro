---
import "@/styles/globals.css";
import Lenis from "lenis";

import Navbar from "@/components/layout/navbar.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Vibrant - The CLI linter that finds what reviews miss. No config. No excuses. Just cleaner code, every time."
    />
    <meta name="theme-color" content="#0a0a0a" />

    <meta
      property="og:title"
      content="Vibrant • Catch vibecoding before they ship"
    />
    <meta
      property="og:description"
      content="The CLI linter that finds what reviews miss. No config. No excuses. Just cleaner code, every time."
    />
    <meta property="og:type" content="website" />

    <title>Vibrant • Catch vibecoding before they ship</title>
  </head>
  <body class="bg-[#edecec] min-h-screen">
    <Navbar />
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>

<script>
  import Lenis from "lenis";

  const lenis = new Lenis({
    duration: 1.2,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    orientation: "vertical",
    gestureOrientation: "vertical",
    smoothWheel: true,
  });

  function raf(time: number) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }

  requestAnimationFrame(raf);
</script>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
