---
import {
  CommandLineIcon,
  BeakerIcon,
  SparklesIcon,
} from "@heroicons/react/24/outline";
import { BlurFade } from "@/components/ui/blur-fade";
import videoInit from "@/assets/videos/vibrant-init.mp4";
import videoDiagnostic from "@/assets/videos/vibrant-diagnostic.mp4";
import videoDiagnosticAi from "@/assets/videos/vibrant-diagnostic-ai.mp4";

interface Props {
  icon: "command" | "beaker" | "sparkles";
  index: number;
  title: string;
  description: string;
  video:
    | "vibrant-init.mp4"
    | "vibrant-diagnostic.mp4"
    | "vibrant-diagnostic-ai.mp4";
}

const { icon, title, description, video, index } = Astro.props;

const videos: Record<string, typeof videoInit> = {
  "vibrant-init.mp4": videoInit,
  "vibrant-diagnostic.mp4": videoDiagnostic,
  "vibrant-diagnostic-ai.mp4": videoDiagnosticAi,
};

const icons: Record<string, typeof CommandLineIcon> = {
  command: CommandLineIcon,
  beaker: BeakerIcon,
  sparkles: SparklesIcon,
};

const IconComponent = icons[icon];
const videoSrc = videos[video];
---

<BlurFade client:visible delay={index == 0 ? 0.8 : 0.2} duration={0.5} inView>
  <div class="group">
    <div
      class="border-2 border-black/5 rounded-2xl p-6 md:p-8 hover:border-black/15 transition-colors duration-300"
    >
      <div class="flex items-center gap-3 mb-4">
        <div class="p-2 bg-black text-white rounded-lg">
          <IconComponent className="size-5" />
        </div>
        <h3 class="text-2xl md:text-3xl font-medium text-black">
          {title}
        </h3>
      </div>
      <p
        class="text-black/60 text-base md:text-lg mb-6 w-full"
        set:html={description}
      />
      <video
        autoplay
        muted
        loop
        playsinline
        class="w-full h-auto rounded-xl border border-black/10"
      >
        <source src={videoSrc} type="video/mp4" />
      </video>
    </div>
  </div></BlurFade
>
