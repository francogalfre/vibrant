---
import logo from "../../assets/logo.png";

import Background from "../background.astro";
---

<section
  class="w-full h-screen flex justify-center items-center flex-col relative overflow-hidden pb-20"
>
  <header
    class="flex flex-col items-center justify-center text-center gap-8 w-full max-w-4xl mx-auto"
  >
    <img
      src={logo.src}
      alt="Vibrant logo"
      class="size-20 transition-all hover:scale-110 hover:rotate-12 duration-500 hover:brightness-105"
    />

    <div class="flex flex-col items-center gap-4">
      <h1 class="z-10 text-7xl font-medium tracking-tight text-white">
        Catch vibecoding before they ship.
      </h1>
      <p class="text-white/80 text-xl max-w-2xl w-full font-light">
        The CLI linter that finds what reviews miss. No config. No excuses. Just
        cleaner code, every time.
      </p>
      <div class="flex items-center gap-4 mt-4">
        <a
          href="https://www.npmjs.com/package/vibrant-cli"
          target="_blank"
          class="px-6 py-3 bg-white text-black font-medium rounded-lg hover:bg-white/90 transition-colors"
        >
          Try in your project
        </a>
        <a
          href="https://github.com/francogalfre/vibrant"
          target="_blank"
          class="px-6 py-3 bg-white/10 text-white font-medium rounded-lg border border-white/20 hover:bg-white/20 transition-colors"
        >
          See docs
        </a>
      </div>
    </div>
  </header>

  <Background />
</section>
