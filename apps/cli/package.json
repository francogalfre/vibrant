{
  "name": "vibrant-cli",
  "version": "0.1.0",
  "description": "🔮 The AI-powered code analyzer that detects vibecoding patterns, security vulnerabilities, and bugs before they reach production",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "vibrant": "./src/bin.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "bun run src/bin.ts",
    "start": "bun run src/bin.ts",
    "vibrant": "bun run src/bin.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.38",
    "@ai-sdk/google": "^3.0.22",
    "@ai-sdk/openai": "^3.0.26",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "ai": "^6.0.77",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "ollama-ai-provider-v2": "^1.2.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "typescript": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "bun": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "keywords": [
    "vibrant",
    "linter",
    "static-analysis",
    "code-quality",
    "code-review",
    "security",
    "vulnerability",
    "bug-detector",
    "ai",
    "ai-generated",
    "vibecode",
    "vibecoding",
    "code-smell",
    "typescript",
    "javascript",
    "cli",
    "developer-tools",
    "eslint-alternative",
    "biome-alternative"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/francogalfre/vibrant.git",
    "directory": "apps/cli"
  },
  "bugs": {
    "url": "https://github.com/francogalfre/vibrant/issues"
  },
  "homepage": "https://github.com/francogalfre/vibrant#readme",
  "author": {
    "name": "Franco Galfré",
    "url": "https://github.com/francogalfre"
  },
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/francogalfre"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
