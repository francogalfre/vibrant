{
  "name": "vibrant-cli",
  "version": "0.1.0",
  "description": "Detect AI-generated code patterns, security vulnerabilities, and bugs before they reach production",
  "type": "module",
  "main": "./src/bin.ts",
  "bin": {
    "vibrant": "./src/bin.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "bun run src/bin.ts",
    "start": "bun run src/bin.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.38",
    "@ai-sdk/google": "^3.0.22",
    "@ai-sdk/openai": "^3.0.26",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "ai": "^6.0.77",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "ollama-ai-provider-v2": "^1.2.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "typescript": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "keywords": [
    "linter",
    "static-analysis",
    "code-quality",
    "security",
    "ai",
    "vibecode",
    "code-review",
    "bug-detector",
    "typescript",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/francogalfre/vibrant.git"
  },
  "bugs": {
    "url": "https://github.com/francogalfre/vibrant/issues"
  },
  "homepage": "https://github.com/francogalfre/vibrant#readme",
  "author": "Franco Galfré",
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/francogalfre"
  }
}
